<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" verbose="1" data-provider-thread-count="2">
    <listeners>
        <listener class-name="runner.ExecutionSetupListener"/>
        <listener class-name="runner.RetryListener"/>
    </listeners>
    <test name="Smoke Tests">
        <classes>
            <class name="runner.SmokeTestRunner"/>
        </classes>
    </test>
</suite>
